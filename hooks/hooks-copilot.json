{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "~/.copilot/hooks/agent-session-start.sh",
        "comment": "Multi-Agent Framework: check agent state and pending items on session start",
        "timeoutSec": 10
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "~/.copilot/hooks/security-scan.sh",
        "comment": "Security: scan staged files for secrets before git commit/push",
        "timeoutSec": 10
      },
      {
        "type": "command",
        "bash": "~/.copilot/hooks/agent-pre-tool-use.sh",
        "comment": "Multi-Agent Framework: enforce agent boundaries",
        "timeoutSec": 5
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "~/.copilot/hooks/agent-post-tool-use.sh",
        "comment": "Multi-Agent Framework: audit log + auto-dispatch",
        "timeoutSec": 5
      },
      {
        "type": "command",
        "bash": "~/.copilot/hooks/agent-staleness-check.sh",
        "comment": "Multi-Agent Framework: detect stale tasks",
        "timeoutSec": 5
      }
    ],
    "agentSwitch": [
      {
        "type": "command",
        "bash": "~/.copilot/hooks/agent-before-switch.sh",
        "comment": "Multi-Agent Framework: validate agent switch before execution",
        "timeoutSec": 5
      },
      {
        "type": "command",
        "bash": "~/.copilot/hooks/agent-after-switch.sh",
        "comment": "Multi-Agent Framework: inject role context after switch",
        "timeoutSec": 5
      }
    ],
    "taskCreate": [
      {
        "type": "command",
        "bash": "~/.copilot/hooks/agent-before-task-create.sh",
        "comment": "Multi-Agent Framework: validate task format and detect duplicates",
        "timeoutSec": 5
      }
    ],
    "taskStatusChange": [
      {
        "type": "command",
        "bash": "~/.copilot/hooks/agent-after-task-status.sh",
        "comment": "Multi-Agent Framework: notify agents + persist memory on status change",
        "timeoutSec": 5
      }
    ],
    "memoryWrite": [
      {
        "type": "command",
        "bash": "~/.copilot/hooks/agent-before-memory-write.sh",
        "comment": "Multi-Agent Framework: deduplicate before writing memory",
        "timeoutSec": 5
      },
      {
        "type": "command",
        "bash": "~/.copilot/hooks/agent-after-memory-write.sh",
        "comment": "Multi-Agent Framework: update FTS5 index after memory write",
        "timeoutSec": 10
      }
    ],
    "compaction": [
      {
        "type": "command",
        "bash": "~/.copilot/hooks/agent-before-compaction.sh",
        "comment": "Multi-Agent Framework: flush memory to file before context compaction",
        "timeoutSec": 10
      }
    ],
    "goalVerified": [
      {
        "type": "command",
        "bash": "~/.copilot/hooks/agent-on-goal-verified.sh",
        "comment": "Multi-Agent Framework: update progress on goal verification",
        "timeoutSec": 5
      }
    ]
  }
}
